{
    "name": "fullsmack/laravel-slice",
    "description": "A simple modules or slice package for Laravel",
    "homepage": "https://github.com/fullsmack/laravel-slice",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "nicolaibaaring"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "FullSmack\\LaravelSlice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test-coverage": "phpunit --coverage-html coverage",
        "test-filter": "phpunit --filter"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FullSmack\\LaravelSlice\\LaravelSliceServiceProvider"
            ]
        }
    }
}
